source .venv/bin/activate
export TORCH_BLAS_PREFER_HIPBLASLT=0
#export ORT_LIB_LOCATION=$HOME/workspace/onnxruntime/build/Linux/Release
#export LIBTORCH=$HOME/workspace/pytorch/torch
#export LIBTORCH_INCLUDE=${LIBTORCH}
export LIBTORCH_USE_PYTORCH=1
export LD_LIBRARY_PATH="\
$PWD/.venv/lib/python3.12/site-packages/torch/lib:\
$HOME/.pyenv/versions/3.12.8/lib/:\
$ORT_LIB_LOCATION"
WORKSPACE=$(cargo metadata --format-version 1 | jq -r ".workspace_root")
export PYTHONPATH=${WORKSPACE}/py:${WORKSPACE}/target/debug
